private void textBox1_KeyPress(object sender, KeyPressEventArgs e)
{
    char myChar = e.KeyChar;  
    int harun = (int)myChar;
    textBox2.Text= harun.ToString();

    string binary=Convert.ToString(harun,2);
    textBox3.Text = binary;
    
}
------------------------------------------------------------------------------------------------------------------------------------------------------------

   private void button1_Click(object sender, EventArgs e)
   {
      int a=int.Parse(textBox1.Text);

       int sayac = 1;

       int toplam=0;

       while(sayac < a) 
       { 
           if(a%sayac==0) 
           {
               toplam += sayac;

           }
           sayac++;
       }

       if(toplam==a)
       {
           label1.Text = "bu sayı mükemmeldir";
       }
       else { label1.Text = "bu sayı mükemmel değildir"; }
          
------------------------------------------------------------------------------------------------------------------------------------------------------------

